# ================================
# SERVER
# ================================
PORT=8080
ENV=development
LOG_LEVEL=debug

# ================================
# DATABASE
# ================================
DATABASE_URL=postgres://amaur:amaur_dev_password@localhost:5432/amaur_db?sslmode=disable
POSTGRES_USER=amaur
POSTGRES_PASSWORD=amaur_dev_password
POSTGRES_DB=amaur_db

# ================================
# JWT
# ================================
JWT_SECRET=change_this_to_a_very_long_random_secret_in_production_min_64_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ================================
# CORS
# ================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ================================
# FILE STORAGE (MinIO / S3)
# ================================
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=

# ================================
# EMAIL (SendGrid)
# ================================
# SENDGRID_API_KEY=
# EMAIL_FROM=no-reply@amaur.cl

# ================================
# SUPERADMIN SEED (automatic at API startup)
# ================================
SEED_ADMIN_EMAIL=admin@amaur.cl
SEED_ADMIN_PASSWORD=ChangeThisNow!2026
SEED_ADMIN_FIRSTNAME=Super
SEED_ADMIN_LASTNAME=Admin
SEED_ADMIN_ON_STARTUP=true
